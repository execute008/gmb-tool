{
  "manifest_version": 3,
  "name": "GMB Audit Tool",
  "version": "0.1.0",
  "description": "Google Business Profile audit and competitor analysis on Google Maps",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.google.com/maps/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GMB Audit Tool"
  },
  "icons": {}
}
